{
  "name": "acam-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Thesis prototype for Active Directory change management and audit correlation.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @acam-ts/contracts && npm run build --workspace api && npm run build --workspace web",
    "dev": "concurrently -k -n api,web \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run start:dev --workspace api",
    "dev:web": "npm run dev --workspace web",
    "docker:build": "docker build -f infra/docker/Dockerfile -t acam-ts:local .",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up --build -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "lint": "npm run lint --workspace api",
    "db:migrate": "npm run build --workspace api && npm run migrate --workspace api",
    "db:setup": "npm run db:migrate",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d postgres",
    "db:down": "docker compose -f infra/docker/docker-compose.yml stop postgres",
    "test": "npm run test --workspace api"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
