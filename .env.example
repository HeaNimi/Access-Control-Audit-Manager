NODE_ENV=development

APP_API_PORT=3001
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001
NUXT_PUBLIC_DEFAULT_UPN_SUFFIX=example.local
NUXT_PUBLIC_DEFAULT_MAIL_DOMAIN=
AUTH_ENABLE_LDAP_LOGIN=true
AUTH_ENABLE_LOCAL_ADMIN_LOGIN=true
AUTH_JWT_SECRET=change-me-jwt-secret
AUTH_JWT_TTL_SECONDS=28800
AUTH_LOCAL_ADMIN_USERNAME=local_admin
AUTH_LOCAL_ADMIN_PASSWORD=change-me-local-admin
AUTH_ROLE_MAP_APPROVER_GROUP_DNS=CN=Approvers,OU=Groups,DC=example,DC=local
AUTH_ROLE_MAP_AUDITOR_GROUP_DNS=
AUTH_ROLE_MAP_ADMINISTRATOR_GROUP_DNS=CN=Admins,OU=Groups,DC=example,DC=local

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=acam_ts
POSTGRES_USER=acam
POSTGRES_PASSWORD=acam
DATABASE_URL=postgres://acam:acam@localhost:5432/acam_ts

DIRECTORY_EXECUTION_SERVICE_ACCOUNT=svc.app.demo
LDAP_URL=ldaps://directory.example.local:636
LDAP_BIND_DN=CN=Service Account,OU=ServiceAccounts,DC=example,DC=local
LDAP_BIND_PASSWORD=change-me
LDAP_START_TLS=false
LDAP_TLS_REJECT_UNAUTHORIZED=true
LDAP_BASE_DN=DC=example,DC=local
LDAP_USERS_OU_DN=OU=Users,DC=example,DC=local
LDAP_UPN_SUFFIX=example.local
SIEM_PULL_ENABLED=false
SIEM_DRIVER=elastic-winlogbeat
SIEM_POLL_INTERVAL_SECONDS=30
SIEM_BATCH_SIZE=100
SIEM_INITIAL_LOOKBACK_SECONDS=3600
SIEM_MAX_FUTURE_SKEW_SECONDS=300
ELASTICSEARCH_NODE=https://localhost:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX=winlogbeat-*
ELASTICSEARCH_TLS_REJECT_UNAUTHORIZED=true
ELASTICSEARCH_EVENT_IDS=4720,4722,4723,4724,4725,4726,4728,4729,4732,4733,4738,4740,4756,4757,4767,4781,5136,5137
ELASTICSEARCH_SOURCE_SYSTEM=elastic-winlogbeat
ELASTICSEARCH_SCOPE_BASE_DN=OU=ManagedObjects,DC=example,DC=local
OBSERVED_EVENT_INGEST_KEY=change-me-ingest-key
